{
  "preset_name": "single_take_feel",
  "description": "Feels like one continuous journey. Wide → mid → close → wide. Observational, not produced.",
  "assembly": {
    "target_duration_sec": 30,
    "avg_cut_sec": 2.5,
    "hero_cut_sec": 4.0,
    "quick_cut_sec": 1.5,
