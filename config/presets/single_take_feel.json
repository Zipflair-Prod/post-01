    "close_with": "wide_arrival",
    "pattern": "wide_mid_close_wide",
    "shot_progression": ["wide", "mid", "close_up", "wide", "mid", "hero_wide"]
  },
  "sound": {
    "open": "ambient_only",
    "ambient_duration_sec": 3,
    "music_entry": "gentle_fade",
    "music_style": "sparse_ambient",
    "diegetic": "continuous_under_music"
  },
  "pacing": { "rhythm": "continuous_flow", "music_led": false },
  "tone": { "energy": "calm_confident", "documentary": true, "authentic_over_polished": true, "prestige": true }
}
